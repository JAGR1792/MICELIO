#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")" && pwd)"
PYTHON_BIN="${PYTHON_BIN:-python3}"

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  echo "Uso: ./micelio <archivo.mice>"
  echo "     ./micelio               # abre REPL"
  echo "Ejemplo: ./micelio hifa_demo_test/app_hifa.mice"
  exit 0
fi

exec "$PYTHON_BIN" "$ROOT_DIR/main.py" "$@"
