importar "gui.mice" como gui
importar "flask.mice" como flask

var tema_inicial = gui.estilo_actual()
var lista_temas = gui.estilos_disponibles()

imp "Tema actual: " + aTexto(tema_inicial)
imp "Temas: " + aTexto(lista_temas)

gui.estilo("forest")
var tema_nuevo = gui.estilo_actual()
imp "Tema cambiado: " + aTexto(tema_nuevo)

var tiene_flask = flask.disponible()
imp "Flask disponible: " + aTexto(tiene_flask)
