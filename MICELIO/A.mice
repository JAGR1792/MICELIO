importar "math.mice" como math
var datos = [3, 2, 1]

datos = datos
  |> map(funcion (x) { x+1 }) # 4,3,2
  |> filter(funcion (x) { x % 2 == 0 }) # 4,2
  |> ordenar() #2,4
  |> reduce(funcion (acc, x) { acc + x }, 0)
  |> map(funcion (x) { x + 19 }) # 25
  |> map(math.raiz) # 5
  |> map(math.entero)
  
  
  
  

imp datos