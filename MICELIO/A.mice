var datos = [1, 2, 3, 4, 5]
var total = datos
	|> map(funcion (x) { x })
	|> filter(funcion (x) { verdadero })
	|> ordenar()
	|> reduce(funcion (acc, x) { acc + x }, 0)

imp total

a= [1,2,3,4]
a=datos 
|> map(funcion (x) { x+1})
|> map(funcion (x) { x+1})
|> map(funcion (x) { x+1})
  

imp a