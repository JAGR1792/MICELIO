{
  "name": "micelio-syntax",
  "displayName": "Micelio Syntax",
  "description": "Syntax highlighting and language configuration for Micelio (.mice)",
  "version": "0.0.7",
  "publisher": "micelio-local",
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:micelio",
    "onCommand:micelio.enterPipe"
  ],
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "commands": [
      {
        "command": "micelio.enterPipe",
        "title": "Micelio: Enter Pipe"
      }
    ],
    "keybindings": [
      {
        "command": "micelio.enterPipe",
        "key": "enter",
        "when": "editorTextFocus && editorLangId == micelio && !editorReadonly && !suggestWidgetVisible && !inSnippetMode"
      }
    ],
    "languages": [
      {
        "id": "micelio",
        "aliases": [
          "Micelio",
          "micelio"
        ],
        "extensions": [
          ".mice",
          ".micelio"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "micelio",
        "scopeName": "source.micelio",
        "path": "./syntaxes/micelio.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "micelio",
        "path": "./snippets/micelio.code-snippets"
      }
    ]
  }
}
