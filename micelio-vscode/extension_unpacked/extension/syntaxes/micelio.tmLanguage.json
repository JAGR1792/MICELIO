{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Micelio",
  "scopeName": "source.micelio",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#booleans-null"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#functions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.number-sign.micelio",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.micelio",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.micelio",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.micelio",
          "match": "\\b(si|sino|segun|caso|defecto|para|hasta|inc|en|mientras|romper|continuar|regresa|importar|como)\\b"
        },
        {
          "name": "storage.type.micelio",
          "match": "\\b(var|const|funcion|set|dict)\\b"
        },
        {
          "name": "support.function.builtin.micelio",
          "match": "\\b(imp|leer|map|filter|reduce|longitud|aNumero|aEntero|aFlotante|aTexto|aBooleano|aCaracter|aCodigo|aBinario|aOctal|aHexadecimal|aBase|aBaseComplemento|aBasecomplemento|aBaseFraccion|aBasefraccion|aBaseConDigitos|aBaseCondigitos|desdeBinario|desdeOctal|desdeHexadecimal|desdeBase|ordenar|tipo|rango|primero|ultimo|invertir|concatenar|aleatorio|abs|maximo|minimo|exp|max_lista|min_lista|suma|producto|promedio|contar|claves|valores|items|todos|alguno|error)\\b"
        }
      ]
    },
    "booleans-null": {
      "patterns": [
        {
          "name": "constant.language.boolean.micelio",
          "match": "\\b(verdadero|falso)\\b"
        },
        {
          "name": "constant.language.null.micelio",
          "match": "\\bnulo\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.micelio",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.micelio",
          "match": "\\b(y|o|no|in)\\b"
        },
        {
          "name": "keyword.operator.micelio",
          "match": "\\|>|\\.\\*|\\+\\+|--|\\*\\*|==|!=|<=|>=|=|<|>|\\+|-|\\*|/|%"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.micelio",
          "match": "(?<=\\bfuncion\\s)[A-Za-z_][A-Za-z0-9_]*"
        }
      ]
    }
  }
}
